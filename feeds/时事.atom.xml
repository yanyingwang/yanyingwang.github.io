  <title type="text">关于新肺中国道歉论的思考</title>
  <link rel="alternate" href="https://yanyingwang.github.io/2020/03/%E5%85%B3%E4%BA%8E%E6%96%B0%E8%82%BA%E4%B8%AD%E5%9B%BD%E9%81%93%E6%AD%89%E8%AE%BA%E7%9A%84%E6%80%9D%E8%80%83.html?utm_source=%E6%97%B6%E4%BA%8B&amp;utm_medium=Atom" />
  <id>urn:https-yanyingwang-github-io:-2020-03-E5-85-B3-E4-BA-8E-E6-96-B0-E8-82-BA-E4-B8-AD-E5-9B-BD-E9-81-93-E6-AD-89-E8-AE-BA-E7-9A-84-E6-80-9D-E8-80-83-html</id>
